{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-env-edits.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/remind-types-regen.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/esm-cjs-drift-check.js"
          }
        ]
      }
    ]
  }
}
